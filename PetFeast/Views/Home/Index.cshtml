@model IEnumerable<PetFeast.Models.Products.Product>

<!-- HERO BANNER -->
<section class="hero-section">

    <div class="container-fluid">

        <div class="row g-3">

            <!-- Banner lớn -->
            <div class="col-lg-8">

                <div id="heroCarousel"
                     class="carousel slide"
                     data-bs-ride="carousel"
                     data-bs-interval="5000">

                    <div class="carousel-inner">

                        <div class="carousel-item active">
                            <img src="~/img/Banner/banner1.jpg"
                                 class="main-banner"
                                 alt="">
                        </div>

                        <div class="carousel-item">
                            <img src="~/img/Banner/banner2.jpg"
                                 class="main-banner"
                                 alt="">
                        </div>

                        <div class="carousel-item">
                            <img src="~/img/Banner/banner3.jpg"
                                 class="main-banner"
                                 alt="">
                        </div>
                    </div>

                    <button class="carousel-control-prev"
                            type="button"
                            data-bs-target="#heroCarousel"
                            data-bs-slide="prev">

                        <span class="carousel-control-prev-icon"></span>

                    </button>

                    <button class="carousel-control-next"
                            type="button"
                            data-bs-target="#heroCarousel"
                            data-bs-slide="next">

                        <span class="carousel-control-next-icon"></span>

                    </button>

                </div>

            </div>

            <!-- Banner bên phải -->
            <div class="col-lg-4">

                <div class="banner-right d-flex flex-column gap-3">

                    <a asp-controller="Product"
                       asp-action="Index"
                       asp-route-categoryId="1">

                        <img src="~/img/Banner/banner_dog.jpg"
                             class="side-banner"
                             alt="Dog">

                    </a>

                    <a asp-controller="Product"
                       asp-action="Index"
                       asp-route-categoryId="2">

                        <img src="~/img/Banner/banner_cat.jpg"
                             class="side-banner"
                             alt="Cat">

                    </a>

                </div>

            </div>

        </div>

    </div>

</section>


<!-- SẢN PHẨM NỔI BẬT -->
<section class="container py-5">

    <h2 class="section-title">Sản phẩm nổi bật</h2>
    <partial name="_ProductSlider"
             model="Model.Take(20)" />
</section>
<!-- THỨC ĂN CHÓ -->
<section class="container py-5">

    <h2 class="section-title">Thức ăn chó</h2>
    <partial name="_ProductSlider"
             model="Model.Where(x => x.CategoryId == 1)" />
</section>
<!-- THỨC ĂN MÈO -->
<section class="container py-5">
    <h2 class="section-title">Thức ăn mèo</h2>
    <partial name="_ProductSlider"
             model="Model.Where(x => x.CategoryId == 2)" />
</section>
<!-- SNACK -->
<section class="container py-5">
    <h2 class="section-title">Snack & Bánh thưởng</h2>
    <partial name="_ProductSlider"
             model="Model.Where(x => x.CategoryId == 3)" />
</section>
<!-- ĐỒ CHƠI -->
<section class="container py-5">
    <h2 class="section-title">Đồ chơi</h2>
    <partial name="_ProductSlider"
             model="Model.Where(x => x.CategoryId == 4)" />
</section>
<!-- PHỤ KIỆN -->
<section class="container py-5">
    <h2 class="section-title">Phụ kiện thú cưng</h2>
    <partial name="_ProductSlider"
             model="Model.Where(x => x.CategoryId == 5)" />
</section>