@model PetFeast.Models.Products.Product

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow mt-4">

    <div class="card-header bg-warning">

        <h4>Sửa sản phẩm</h4>

    </div>

    <div class="card-body">

        <form asp-action="EditProduct"
              method="post"
              enctype="multipart/form-data">

            <input hidden asp-for="ProductId">

            <input hidden asp-for="ImageUrl">

            <div class="mb-3">

                <label>Tên sản phẩm</label>

                <input asp-for="ProductName"
                       class="form-control">

            </div>

            <div class="mb-3">

                <label>Giá</label>

                <input asp-for="Price"
                       class="form-control">

            </div>
            <div class="mb-3">

                <label>Giảm giá (%)</label>

                <input asp-for="DiscountPercent"
                       class="form-control"
                       min="0"
                       max="100">

            </div>

            <div class="mb-3">

                <label>Số lượng</label>

                <input asp-for="Quantity"
                       class="form-control">

            </div>

            <div class="mb-3">

                <label>Danh mục</label>

                <select asp-for="CategoryId"
                        class="form-select"
                        asp-items="@(new SelectList(ViewBag.Categories, "CategoryId", "CategoryName"))">
                </select>

            </div>

            <div class="mb-3">

                <label>Mô tả</label>

                <textarea asp-for="Description"
                          class="form-control"></textarea>

            </div>

            <div class="mb-3">

                <label>Ảnh hiện tại</label>

                <br>

                <img src="@Model.ImageUrl"
                     width="150"
                     class="rounded border">

            </div>

            <div class="mb-3">

                <label>Ảnh mới</label>

                <input asp-for="ImageFile"
                       class="form-control">

            </div>

            <button class="btn btn-warning">

                Cập nhật

            </button>

            <a asp-action="ProductList"
               class="btn btn-secondary">

                Hủy

            </a>

        </form>

    </div>

</div>