@model PetFeast.Models.Products.Product


<div class="container mt-5 mb-5">
    <div class="row detail-product align-items-center g-5">
        <!-- IMAGE -->
        <div class="col-lg-6">
            <div class="product-image-box">
                <img src="@Model.ImageUrl"
                     class="img-fluid"
                     alt="@Model.ProductName">
            </div>
        </div>
        <!-- INFO -->
        <div class="col-lg-6">
            <h1 class="fw-bold text-primary mb-3">
                @Model.ProductName
            </h1>
            @if (Model.DiscountPercent > 0)
            {
                <h4 class="text-muted">
                    <del>
                        @Model.Price.ToString("N0") đ
                    </del>
                </h4>

                <h2 class="text-danger fw-bold mb-3">
                    @Model.DiscountPrice.ToString("N0") đ
                </h2>

                <span class="badge bg-danger">
                    Giảm @Model.DiscountPercent%
                </span>
            }
            else
            {
                <h2 class="text-danger fw-bold mb-3">
                    @Model.Price.ToString("N0") đ
                </h2>
            }

            @if (Model.Quantity > 0)
            {
                <p class="text-success fw-bold mb-3">
                    Còn @Model.Quantity sản phẩm
                </p>
            }
            else
            {
                <p class="text-danger fw-bold mb-3">
                    Hết hàng
                </p>
            }
            <div class="product-description mb-4">
                <h5 class="fw-bold">
                    Mô tả sản phẩm
                </h5>
                <p class="text-secondary">
                    @Model.Description
                </p>
            </div>
            <form asp-controller="ShoppingCart"
                  asp-action="AddToCart"
                  method="post">
                <input type="hidden"
                       name="productId"
                       value="@Model.ProductId" />
                <div class="d-flex align-items-center mb-4">
                    <label class="fw-bold me-3">
                        Số lượng:
                    </label>
                    <input type="number"
                           name="quantity"
                           value="1"
                           min="1"
                           max="@Model.Quantity"
                           class="form-control quantity-box">
                </div>
                @if (Model.Quantity > 0)
                {
                    <button class="btn btn-primary btn-lg w-100 fw-bold add-cart-btn">
                        <i class="bi bi-cart-plus"></i>
                        THÊM VÀO GIỎ HÀNG
                    </button>
                }
                else
                {
                    <button class="btn btn-secondary btn-lg w-100 fw-bold add-cart-btn"
                            disabled>
                        HẾT HÀNG
                    </button>
                }
            </form>
        </div>
    </div>
</div>
<div class="container mt-5 mb-5">


    <h2 class="fw-bold text-primary mb-4">
        Sản phẩm liên quan
    </h2>


    <div class="row g-4">


        @foreach (var item in ViewBag.RelatedProducts)
        {

            <div class="col-md-3">


                <a asp-controller="Product"
                   asp-action="Detail"
                   asp-route-id="@item.ProductId"
                   class="text-decoration-none text-dark">


                    <div class="card h-100 product-card">


                        <img src="@item.ImageUrl"
                             class="card-img-top"
                             style="height:220px;object-fit:contain">


                        <div class="card-body">


                            <h5>
                                @item.ProductName
                            </h5>


                            @if (item.DiscountPercent > 0)
                            {

                                <del class="text-muted">
                                    @item.Price.ToString("N0") đ
                                </del>

                                <h5 class="text-danger fw-bold">
                                    @item.DiscountPrice.ToString("N0") đ
                                </h5>

                            }
                            else
                            {

                                <h5 class="text-danger fw-bold">
                                    @item.Price.ToString("N0") đ
                                </h5>

                            }
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>