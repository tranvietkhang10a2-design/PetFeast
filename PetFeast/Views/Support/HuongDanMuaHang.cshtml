@{
    ViewData["Title"] = "Hướng dẫn mua hàng";
}

<div class="main-content">

    <div class="container">
<div class="policy-banner">
    <h1>Hướng dẫn mua hàng</h1>

    <p>
        PetFeast mang đến trải nghiệm mua sắm đơn giản, nhanh chóng
        và thuận tiện cho khách hàng.
    </p>
</div>
<div class="row g-4">

    <div class="col-md-3">
        <div class="policy-card">
            <i class="bi bi-search"></i>

            <h5 class="mt-3">Tìm kiếm sản phẩm</h5>

            <p>
                Lựa chọn sản phẩm phù hợp với thú cưng.
            </p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="policy-card">
            <i class="bi bi-cart-plus"></i>

            <h5 class="mt-3">Thêm vào giỏ hàng</h5>

            <p>
                Chọn số lượng và thêm sản phẩm vào giỏ.
            </p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="policy-card">
            <i class="bi bi-credit-card"></i>

            <h5 class="mt-3">Thanh toán</h5>

            <p>
                Kiểm tra thông tin và xác nhận đơn hàng.
            </p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="policy-card">
            <i class="bi bi-truck"></i>

            <h5 class="mt-3">Nhận hàng</h5>

            <p>
                Giao hàng nhanh chóng và an toàn.
            </p>
        </div>
    </div>

</div>
<div class="policy-content mt-5">

    <h3>Quy trình mua hàng tại PetFeast</h3>

    <p>
        Khách hàng có thể dễ dàng tìm kiếm sản phẩm thông qua danh mục
        hoặc thanh tìm kiếm. Sau khi lựa chọn sản phẩm phù hợp, khách hàng
        thêm vào giỏ hàng và tiến hành thanh toán.
    </p>

    <p>
        Hệ thống sẽ xác nhận đơn hàng và tiến hành giao hàng trong thời gian
        sớm nhất nhằm đảm bảo mang đến trải nghiệm tốt nhất cho khách hàng.
    </p>

</div>
</div> 
</div> 