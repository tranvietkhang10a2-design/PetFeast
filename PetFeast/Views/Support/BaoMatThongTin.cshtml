@{
    ViewData["Title"] = "Bảo mật thông tin";
}


<div class="main-content">

    <div class="container">


        <div class="policy-banner">

            <h1>Bảo mật thông tin</h1>

            <p>
                PetFeast cam kết bảo mật tuyệt đối thông tin cá nhân của khách hàng
            </p>

        </div>
        <div class="row g-4">

            <div class="col-md-3">

                <div class="policy-card">

                    <i class="bi bi-shield-lock"></i>

                    <h5>Bảo mật dữ liệu</h5>

                    <p>
                        Thông tin khách hàng được lưu trữ an toàn.
                    </p>

                </div>

            </div>


            <div class="col-md-3">

                <div class="policy-card">

                    <i class="bi bi-envelope"></i>

                    <h5>Email</h5>

                    <p>
                        Chỉ dùng để xác nhận đơn hàng và hỗ trợ khách hàng.
                    </p>

                </div>

            </div>


            <div class="col-md-3">

                <div class="policy-card">

                    <i class="bi bi-telephone"></i>

                    <h5>Số điện thoại</h5>

                    <p>
                        Hỗ trợ liên hệ và chăm sóc khách hàng.
                    </p>

                </div>

            </div>


            <div class="col-md-3">

                <div class="policy-card">

                    <i class="bi bi-house-door"></i>

                    <h5>Địa chỉ nhận hàng</h5>

                    <p>
                        Đảm bảo quá trình giao hàng chính xác.
                    </p>

                </div>

            </div>

        </div>
        <div class="row g-4 mt-4">

            <div class="col-md-4">

                <div class="policy-card">

                    <i class="bi bi-lock"></i>

                    <h5>Bảo mật tuyệt đối</h5>

                    <p>
                        Thông tin khách hàng được mã hóa và bảo vệ an toàn.
                    </p>

                </div>

            </div>


            <div class="col-md-4">

                <div class="policy-card">

                    <i class="bi bi-person-check"></i>

                    <h5>Tôn trọng khách hàng</h5>

                    <p>
                        Không sử dụng thông tin sai mục đích.
                    </p>

                </div>

            </div>


            <div class="col-md-4">

                <div class="policy-card">

                    <i class="bi bi-shield-check"></i>

                    <h5>Minh bạch</h5>

                    <p>
                        Cam kết tuân thủ các quy định về bảo mật dữ liệu.
                    </p>

                </div>

            </div>

        </div>
        <div class="policy-content mt-5">

            <h3>Cam kết của PetFeast</h3>

            <p>
                PetFeast luôn đặt quyền riêng tư của khách hàng lên hàng đầu.
                Chúng tôi không ngừng cải thiện hệ thống nhằm đảm bảo dữ liệu
                được bảo mật tốt nhất, đồng thời mang đến môi trường mua sắm
                trực tuyến an toàn và đáng tin cậy.
            </p>

        </div>

    </div>

</div>