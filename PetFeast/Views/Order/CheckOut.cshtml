@model List<PetFeast.Models.ShoppingCart.ShoppingCartItem>


<div class="container mt-4">
    <form asp-action="CheckOut" 
    asp-controller="Order"
          method="post">
        <div class="row">
            <!-- BÊN TRÁI -->
            <div class="col-lg-8">
                <!-- Thông tin khách hàng -->
                <div class="card border-0 shadow-sm p-4 mb-4">
                    <h4 class="fw-bold mb-4">
                        Thông tin khách hàng
                    </h4>
                    <div class="row">
                        <div class="col-md-6">
                            <input class="form-control"
                                   name="CustomerName"
                                   placeholder="Tên khách hàng *"
                                   required />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control"
                                   name="Phone"
                                   placeholder="Số điện thoại *"
                                   required />
                        </div>
                    </div>
                </div>
                <!-- Hình thức nhận hàng -->
                <div class="card border-0 shadow-sm p-4 mb-4">
                    <h4 class="fw-bold mb-4">
                        Hình thức nhận hàng
                    </h4>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input"
                               type="radio"
                               name="DeliveryMethod"
                               value="Ship"
                               checked>
                        <label class="form-check-label">
                            Giao hàng tận nơi
                        </label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input"
                               type="radio"
                               name="DeliveryMethod"
                               value="Store">
                        <label class="form-check-label">
                            Nhận tại cửa hàng
                        </label>
                    </div>
                    <div class="row mt-4">
                        <div class="col-md-6">
                            <input class="form-control"
                                   placeholder="Tỉnh/Thành phố *"
                                   name="city"
                                   required>
                        </div>
                        <div class="col-md-6">
                            <input class="form-control"
                                   placeholder="Phường/Xã *"
                                   name="ward"
                                   required>
                        </div>
                    </div>
                    <textarea class="form-control mt-3"
                              placeholder="Địa chỉ nhận hàng *"
                              name="Address"
                              required></textarea>
                </div>
                <!-- Sản phẩm -->
                <div class="card border-0 shadow-sm p-4 mb-4">
                    <h4 class="fw-bold mb-4">
                        Sản phẩm (@Model.Count)
                    </h4>
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Đơn giá</th>
                                <th>Số lượng</th>
                                <th>Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="@item.ImageUrl"
                                                 width="70"
                                                 height="70"
                                                 style="object-fit:cover"
                                                 class="me-3 rounded" />
                                            <span>
                                                @item.ProductName
                                            </span>
                                        </div>
                                    </td>
                                    <td>
                                        @item.Price.ToString("N0") đ
                                    </td>
                                    <td>
                                        x @item.Quantity
                                    </td>
                                    <td class="text-danger fw-bold">
                                        @item.TotalPrice.ToString("N0") đ
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <!-- Thanh toán -->
                <div class="card border-0 shadow-sm p-4 mb-4">
                    <h4 class="fw-bold mb-4">
                        Phương thức thanh toán
                    </h4>
                    <div class="form-check">
                        <input class="form-check-input"
                               type="radio"
                               name="PaymentMethod"
                               value="COD"
                               checked>
                        <label class="form-check-label">
                            Thanh toán khi nhận hàng (COD)
                        </label>
                    </div>
                </div>
            </div>
            <!-- BÊN PHẢI -->
            <div class="col-lg-4">
                <!-- Ghi chú -->
                <div class="card border-0 shadow-sm p-4 mb-3">
                    <h5 class="fw-bold mb-3">
                        Ghi chú đơn hàng
                    </h5>
                    <textarea class="form-control"
                              rows="5"
                              placeholder="Thêm ghi chú (tuỳ chọn)"
                              name="Note"></textarea>
                </div>
                <!-- Ưu đãi -->
                <div class="card border-0 shadow-sm p-4 mb-3">

                    <h5 class="fw-bold mb-3">
                        Mã ưu đãi
                    </h5>


                    <div class="input-group">

                        <input type="text"
                               class="form-control"
                               name="CouponCode"
                               placeholder="Nhập mã ưu đãi" />


                        <button type="button"
                                class="btn btn-primary">

                            Áp dụng

                        </button>

                    </div>


                </div>
                <!-- Chi tiết thanh toán -->
                <div class="card border-0 shadow-sm p-4">
                    <h4 class="fw-bold mb-4">
                        Chi tiết thanh toán
                    </h4>
                    <div class="d-flex justify-content-between mb-3">
                        <span>
                            Tổng tiền hàng
                        </span>
                        <span>
                            @(Model.Sum(x => x.TotalPrice).ToString("N0")) đ
                        </span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between mb-4">
                        <strong>
                            Tổng tiền thanh toán
                        </strong>
                        <strong class="text-danger fs-4">
                            @(Model.Sum(x => x.TotalPrice).ToString("N0")) đ
                        </strong>
                    </div>
                    <button type="submit"
                            class="btn btn-warning w-100 fw-bold">
                        Đặt hàng
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>