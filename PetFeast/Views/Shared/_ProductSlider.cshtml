@model IEnumerable<PetFeast.Models.Products.Product>

@{
    var sliderId = "slider_" + Guid.NewGuid().ToString("N");
}

<div class="product-slider-wrapper">

    <button class="btn btn-primary slider-btn slider-prev"
            onclick="scrollSlider('@sliderId', -1)">
        ❮
    </button>

    <div class="product-scroll" id="@sliderId">

        @foreach (var item in Model)
        {
            <div class="product-item">

                <div class="card h-100 shadow-sm product-card">


                    <a asp-controller="Product"
                       asp-action="Detail"
                       asp-route-id="@item.ProductId"
                       class="product-image-link">


                        <img src="@item.ImageUrl"
                             class="card-img-top"
                             style="height:250px; object-fit:cover;"
                             alt="@item.ProductName">


                    </a>



                    <div class="card-body text-center">


                        <h6>
                            @item.ProductName
                        </h6>


                        <p class="text-primary fw-bold">

                            @item.Price.ToString("N0") đ

                        </p>



                        <form asp-controller="ShoppingCart"
                              asp-action="AddToCart"
                              method="post">


                            <input type="hidden"
                                   name="productId"
                                   value="@item.ProductId" />


                            <input type="hidden"
                                   name="quantity"
                                   value="1" />



                            <button type="submit"
                                    class="btn btn-primary w-100">


                                <i class="bi bi-cart-plus"></i>

                                Thêm vào giỏ


                            </button>


                        </form>


                    </div>


                </div>


            </div>
        }

    </div>

    <button class="btn btn-primary slider-btn slider-next"
            onclick="scrollSlider('@sliderId', 1)">
        ❯
    </button>

</div>