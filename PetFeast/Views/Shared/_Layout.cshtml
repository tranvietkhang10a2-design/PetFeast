                    <div class="service-icon">

                        <i class="bi bi-arrow-repeat"></i>

                    </div>


                    <h5>
                        Đổi trả miễn phí
                    </h5>

                    <p>
                        Trong vòng 7 ngày
                    </p>

                </div>


            </div>

        </div>

    </section>

    <footer>

        <div class="footer-top-bar"></div>

        <div class="footer-content">

            <div class="container">

                <div class="row justify-content-center text-center">

                    <div class="col-lg-3 col-md-6 mb-4">

                        <h2 class="footer-logo">
                            <img src="~/img/Logo/logo.png"
                                 alt="PetFeast Logo"
                                 class="footer-logo-img">
                        </h2>

                        <p>
                            Thức ăn và phụ kiện chất lượng dành cho thú cưng.
                        </p>

                        <div class="social-icons">

                            <a href="#">
                                <i class="bi bi-facebook"></i>
                            </a>

                            <a href="#">
                                <i class="bi bi-instagram"></i>
                            </a>

                            <a href="#">
                                <i class="bi bi-tiktok"></i>
                            </a>

                        </div>

                    </div>

                    <div class="col-lg-3 col-md-6 mb-4">

                        <h5>Liên hệ</h5>

                        <p>📞 0886 469 752</p>

                        <p>✉ petfeast@gmail.com</p>

                        <p>📍 Đà Lạt, Lâm Đồng</p>

                    </div>

                    <div class="col-lg-3 col-md-6 mb-4">

                        <h5>Hỗ trợ</h5>

                        <ul class="footer-links">

                            <li><a href="#">Hướng dẫn mua hàng</a></li>

                            <li><a href="#">Chính sách giao hàng</a></li>

                            <li><a href="#">Chính sách đổi trả</a></li>

                        </ul>

                    </div>

                    <div class="col-lg-3 col-md-6 mb-4">

                        <h5>Chính sách</h5>

                        <ul class="footer-links">

                            <li><a href="#">Điều khoản sử dụng</a></li>

                            <li><a href="#">Bảo mật thông tin</a></li>

                            <li><a href="#">Liên hệ</a></li>

                        </ul>

                    </div>

                </div>

            </div>

        </div>

        <div class="footer-bottom">

            © 2026 PetFeast - All Rights Reserved

        </div>

    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
                       function scrollSlider(id, direction) {

            const slider = document.getElementById(id);

            const card = slider.querySelector('.product-item');

            if (!card) return;


            const distance = (card.offsetWidth + 20) * direction;

            const start = slider.scrollLeft;

            const end = start + distance;

            const duration = 600; // thời gian trượt (ms)

            let startTime = null;


            function animation(currentTime) {

                if (!startTime)
                    startTime = currentTime;


                const progress = Math.min(
                    (currentTime - startTime) / duration,
                    1
                );


                // easing mượt
                const ease =
                    1 - Math.pow(1 - progress, 3);


                slider.scrollLeft =
                    start + (end - start) * ease;


                if (progress < 1) {

                    requestAnimationFrame(animation);

                }

            }


            requestAnimationFrame(animation);

        }

        window.addEventListener('load', function () {

            document.querySelectorAll('.product-scroll').forEach(slider => {

                let isDown = false;
                let startX;
                let scrollLeft;

                slider.addEventListener('mousedown', e => {

                    isDown = true;
                    startX = e.pageX - slider.offsetLeft;
                    scrollLeft = slider.scrollLeft;

                });

                slider.addEventListener('mouseleave', () => isDown = false);
                slider.addEventListener('mouseup', () => isDown = false);

                slider.addEventListener('mousemove', e => {

                    if (!isDown) return;

                    e.preventDefault();

                    const x = e.pageX - slider.offsetLeft;
                    const walk = (x - startX) * 2;

                    slider.scrollLeft = scrollLeft - walk;

                });

            });

        });
    </script>

    @await RenderSectionAsync("Scripts", false)

</body>
</html>