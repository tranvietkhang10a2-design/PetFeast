@inject IHttpContextAccessor HttpContextAccessor

@{
    var cartCount =
        HttpContextAccessor?.HttpContext?.Session
        .GetInt32("CartCount") ?? 0;
}
<!DOCTYPE html>
<html lang="vi">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>PetFeast</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/swiper/swiper-bundle.min.css">

    <link rel="stylesheet" href="~/css/site.css" />

</head>

<body>

    <!-- HEADER -->
    <header class="border-bottom bg-white">

        <div class="container">

            <div class="row header-row">

                <!-- LOGO -->
                <div class="col-lg-3">

                    <a asp-controller="Home"
                       asp-action="Index"
                       class="logo-link">

                        <img src="~/img/Logo/logo.png"
                             alt="PetFeast Logo"
                             class="logo-img">

                    </a>

                </div>


                <!-- SEARCH -->
                <div class="col-lg-6">
                    <form asp-controller="Product"
                          asp-action="Index"
                          method="get"
                          class="w-100 header-search">
                        <div class="input-group">

                            <input type="text"
                                   name="keyword"
                                   class="form-control"
                                   placeholder="Tìm kiếm sản phẩm..." />

                            <button type="submit"
                                    class="btn btn-primary">
                                Tìm kiếm
                            </button>

                        </div>

                    </form>

                </div>
                

                <!-- ACCOUNT + CART -->
                <div class="col-lg-3">

                    <ul class="navbar-nav flex-row justify-content-end align-items-center w-100">


                        <li class="nav-item">

                            <a class="nav-link text-dark btn-login">

                                Login

                            </a>

                        </li>


                        <li class="nav-item ms-3">

                            <a asp-controller="ShoppingCart"
                               asp-action="Index"
                               class="btn btn-primary cart-icon">

                                <i class="bi bi-cart3"></i>

                                <span>(@cartCount)</span>

                            </a>

                        </li>


                    </ul>

                </div>


            </div>

        </div>

    </header>
    <!-- MENU -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">

        <div class="container">

            <ul class="navbar-nav">

                <!-- Trang chủ -->
                <li class="nav-item">

                    <a class="nav-link"
                       asp-controller="Home"
                       asp-action="Index">

                        Trang chủ

                    </a>

                </li>

                <!-- Sản phẩm Dropdown -->
                <li class="nav-item dropdown">

                    <a class="nav-link dropdown-toggle"
                       href="#"
                       role="button"
                       data-bs-toggle="dropdown">

                        Sản phẩm

                    </a>

                    <ul class="dropdown-menu">

                        <li>
                            <a class="dropdown-item"
                               asp-controller="Product"
                               asp-action="Index">

                                Tất cả sản phẩm

                            </a>
                        </li>

                        <li><hr class="dropdown-divider"></li>

                        <li>
                            <a class="dropdown-item"
                               asp-controller="Product"
                               asp-action="Index"
                               asp-route-categoryId="1">Thức ăn chó
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item"
                               asp-controller="Product"
                               asp-action="Index"
                               asp-route-categoryId="2">Thức ăn mèo
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item"
                               asp-controller="Product"
                               asp-action="Index"
                               asp-route-categoryId="3">Snack & Bánh thưởng</a>
                        </li>
                        <li>
                            <a class="dropdown-item"
                               asp-controller="Product"
                               asp-action="Index"
                               asp-route-categoryId="4">Đồ chơi</a>
                        </li>
                        <li>
                            <a class="dropdown-item"
                               asp-controller="Product"
                               asp-action="Index"
                               asp-route-categoryId="5">Phụ kiện</a>
                        </li>
                    </ul>
                </li>

                <!-- Khuyến mãi -->
                <li class="nav-item">

                    <a class="nav-link"
                       asp-controller="Home"
                       asp-action="Promotion">

                        Khuyến mãi

                    </a>

                </li>
                <li class="nav-item">

                    <a class="nav-link"
                       asp-controller="Home"
                       asp-action="About">

                        Về chúng tôi

                    </a>

                </li>
                <!-- Liên hệ -->
