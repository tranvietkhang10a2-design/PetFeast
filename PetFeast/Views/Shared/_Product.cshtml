@model PetFeast.Models.Products.Category

<div class="container mt-5">

    <h2>Thêm danh mục</h2>

    <form asp-action="Create">

        <div class="mb-3">

            <label asp-for="CategoryName"
                   class="form-label">
            </label>

            <input asp-for="CategoryName"
                   class="form-control" />

            <span asp-validation-for="CategoryName"
                  class="text-danger">
            </span>

        </div>

        <button type="submit"
                class="btn btn-danger">

            Thêm

        </button>

    </form>

</div>